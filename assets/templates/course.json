{
  "id": "course",
  "name": "课程论文",
  "description": "曲阜师范大学课程论文报告格式，带学校Logo封面和个人信息表。封面使用华文行楷/黑体初号字。",
  "source": "builtin",

  "page_setup": {
    "paper": { "width_mm": 210, "height_mm": 297 },
    "margins": { "top_mm": 25, "bottom_mm": 25, "left_mm": 25, "right_mm": 25 },
    "gutter_mm": 0,
    "default_line_spacing": 1.0
  },

  "styles": {
    "CoverSchool": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "华文行楷",
      "font_size_pt": 42,
      "bold": false,
      "alignment": "center",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "CoverCourse": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "华文行楷",
      "font_size_pt": 42,
      "bold": true,
      "alignment": "center",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "CoverReport": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "黑体",
      "font_size_pt": 42,
      "bold": false,
      "alignment": "center",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "CoverDate": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "宋体",
      "font_size_pt": 15,
      "bold": true,
      "alignment": "center",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "StudentInfo": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "仿宋_GB2312",
      "font_size_pt": 12,
      "bold": false,
      "alignment": "center",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "Title": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "黑体",
      "font_size_pt": 16,
      "bold": false,
      "alignment": "center",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "TitleInfo": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "仿宋_GB2312",
      "font_size_pt": 12,
      "bold": false,
      "alignment": "center",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "TOC_Title": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "黑体",
      "font_size_pt": 14,
      "bold": true,
      "alignment": "center",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "TOC_Level1": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "宋体",
      "font_size_pt": 12,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "TOC_Level2": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "宋体",
      "font_size_pt": 12,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.0,
      "first_line_indent_chars": 2
    },

    "Abstract": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "宋体",
      "font_size_pt": 10.5,
      "bold": false,
      "alignment": "justify",
      "line_spacing": 1.0,
      "first_line_indent_chars": 2
    },
    "AbstractLabel": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "黑体",
      "font_size_pt": 10.5,
      "bold": true,
      "alignment": "left",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "Abstract_EN": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "Times New Roman",
      "font_size_pt": 10.5,
      "bold": false,
      "alignment": "justify",
      "line_spacing": 1.0,
      "first_line_indent_chars": 2
    },
    "AbstractLabel_EN": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "Times New Roman",
      "font_size_pt": 10.5,
      "bold": true,
      "alignment": "left",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "Keywords": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "宋体",
      "font_size_pt": 10.5,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },
    "Keywords_EN": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "Times New Roman",
      "font_size_pt": 10.5,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    },

    "Heading1": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "仿宋_GB2312",
      "font_size_pt": 14,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.0,
      "space_before_pt": 6,
      "space_after_pt": 0,
      "first_line_indent_chars": 0,
      "outline_level": 0
    },
    "Heading2": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "黑体",
      "font_size_pt": 12,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.0,
      "space_before_pt": 0,
      "space_after_pt": 0,
      "first_line_indent_chars": 0,
      "outline_level": 1
    },
    "Heading3": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "仿宋_GB2312",
      "font_size_pt": 12,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.0,
      "space_before_pt": 0,
      "space_after_pt": 0,
      "first_line_indent_chars": 0,
      "outline_level": 2
    },
    "BodyText": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "宋体",
      "font_size_pt": 12,
      "bold": false,
      "alignment": "justify",
      "line_spacing": 1.0,
      "space_before_pt": 0,
      "space_after_pt": 0,
      "first_line_indent_chars": 2
    },
    "Reference": {
      "font_ascii": "Times New Roman",
      "font_east_asia": "宋体",
      "font_size_pt": 10.5,
      "bold": false,
      "alignment": "left",
      "line_spacing": 1.0,
      "first_line_indent_chars": 0
    }
  },

  "abstract_format": "inline",
  "_abstract_format_note": "'inline'表示「摘要：×××…」标签加粗后紧跟内容在同一段落，左对齐。'block'表示标签独立居中段落+内容另起段。",

  "page_order": [
    { "section": "cover", "page_break_after": true },
    { "section": "toc", "page_break_after": true },
    { "section": "title_page", "page_break_after": false },
    { "section": "abstract_zh", "page_break_after": false },
    { "section": "abstract_en", "page_break_after": false },
    { "section": "body", "page_break_after": false },
    { "section": "references", "page_break_after": false }
  ],

  "cover": {
    "enabled": true,
    "source_template": "assets/qfnu-template-course.docx",
    "paragraphs_boundary": null,
    "placeholders": {
      "course_name": {
        "type": "paragraph",
        "style": "CoverCourse",
        "default": "<课程名称>"
      },
      "title": {
        "type": "table_cell",
        "table_index": 0,
        "label": "题    目",
        "default": "论文题目"
      },
      "student_name": {
        "type": "table_cell",
        "table_index": 0,
        "label": "姓    名",
        "default": "学生姓名"
      },
      "department": {
        "type": "table_cell",
        "table_index": 0,
        "label": "院    系",
        "default": "xxxx学院"
      },
      "major": {
        "type": "table_cell",
        "table_index": 0,
        "label": "专    业",
        "default": "xxxx专业"
      },
      "advisor": {
        "type": "table_cell",
        "table_index": 0,
        "label": "指导教师",
        "default": "指导教师姓名"
      },
      "date": {
        "type": "paragraph",
        "style": "CoverDate",
        "format": "年   月   日"
      }
    }
  },

  "toc": {
    "title_style": "TOC_Title",
    "levels": [
      { "heading_level": 1, "style": "TOC_Level1", "indent_chars": 0 },
      { "heading_level": 2, "style": "TOC_Level2", "indent_chars": 2 }
    ],
    "tab_stop_cm": 14.5
  },

  "title_page": {
    "title_cn_style": "Title",
    "info_styles": ["TitleInfo"],
    "info_fields": [
      { "key": "student", "label": "学生" },
      { "key": "advisor", "label": "指导教师" }
    ]
  },

  "heading_levels": [
    { "level": 1, "style": "Heading1", "numbering_pattern": "\\d+\\s+", "outline_level": 0 },
    { "level": 2, "style": "Heading2", "numbering_pattern": "\\d+\\.\\d+\\s+", "outline_level": 1 },
    { "level": 3, "style": "Heading3", "numbering_pattern": "\\d+\\.\\d+\\.\\d+\\s+", "outline_level": 2 }
  ],

  "references": {
    "title_style": "Heading1",
    "body_style": "Reference",
    "title_text": "参考文献"
  },

  "word_count_estimate": {
    "chars_per_page_single_spacing": 1500
  }
}
